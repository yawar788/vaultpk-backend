# ─── SERVER ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────
# Get this from https://cloud.mongodb.com (free tier)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vaultpk?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────
# Any long random string — keep this SECRET
JWT_SECRET=vaultpk_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# ─── CLOUDINARY (for product images) ─────────────
# Get free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── ADMIN ────────────────────────────────────────
# This email will be auto-set as admin on first register
ADMIN_EMAIL=admin@vaultpk.com
